alias monram="while true; do clear; date; topram; sleep 5; done"
alias topram="echo '=================================================='; total_pct=\$(ps -ax -o %mem | awk '{sum+=\$1} END {print sum}'); total_gb=\$(echo \"(\$total_pct * 32) / 100\" | bc -l); printf 'RAM TOTAL USADA: %.2f GB / 32.00 GB\n' \$total_gb; swap_line=\$(/usr/sbin/sysctl -n vm.swapusage); used_swap=\$(echo \"\$swap_line\" | awk -F'used = ' '{print \$2}' | awk '{print \$1}'); echo \"SWAP EN USO: \"\$used_swap; pressure_num=\$(/usr/sbin/sysctl -n vm.memory_pressure 2>/dev/null || echo 0); if [ \$pressure_num -lt 70 ]; then echo \"ESTADO DE RAM: NORMAL (VERDE)\"; elif [ \$pressure_num -lt 90 ]; then echo \"ESTADO DE RAM: ADVERTENCIA (AMARILLO)\"; else echo \"ESTADO DE RAM: CRÍTICO (ROJO)\"; fi; if [ -f /usr/local/bin/smccmd ]; then /usr/local/bin/smccmd -f 2>/dev/null | awk '/Fan #/ {fan=\$2; gsub(/[:#]/,\"\",fan)} /Current speed/ {printf \"VENTILADOR %d: %s RPM\n\", fan+1, \$4}'; temp_cpu=\$(/usr/local/bin/smccmd -r -k Tp09 2>/dev/null | awk '{print \$4}' | sed 's/[^0-9.]//g'); temp_gpu=\$(/usr/local/bin/smccmd -r -k Tg05 2>/dev/null | awk '{print \$4}' | sed 's/[^0-9.]//g'); if [ ! -z \"\$temp_cpu\" ] && [ \"\$temp_cpu\" != \"0\" ] && [ \"\$temp_cpu\" != \"00\" ]; then printf 'TEMP CPU CORES: %.1f °C\n' \"\$temp_cpu\"; fi; if [ ! -z \"\$temp_gpu\" ] && [ \"\$temp_gpu\" != \"0\" ] && [ \"\$temp_gpu\" != \"00\" ]; then printf 'TEMP GPU CORES: %.1f °C\n' \"\$temp_gpu\"; fi; fi; echo '=================================================='; ps -ax -o pid,rss,%mem,comm | sort -nr -k 2 | head -n6 | awk 'BEGIN {print \"PID\tRAM (GB)\t%MEM\tCOMMAND\"} {printf \"%s\t%.1f GB\t%s%%\t%s\n\", \$1, \$2/1048576, \$3, \$4}'"
