{
  "$schema": "https://githubusercontent.com",
  "enabled": true,
  "debug": true,
  "pruneNotification": "minimal",
  "pruneNotificationType": "chat",
  "compress": {
    "mode": "range",
    "showCompression": true,
    "maxContextLimit": 65536,
    "minContextLimit": 65536,
    "summaryBuffer": false,
    "nudgeFrequency": 99
  }
}
