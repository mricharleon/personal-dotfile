{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "~/.config/opencode/**": "allow",
      "/home/kali/macbookpro/**": "allow"
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": false
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "@modelcontextprotocol/server-filesystem@latest",
        "/home/kali/development"
      ],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "@upstash/context7-mcp@latest"
      ],
      "enabled": true
    },
    "notion": {
      "type": "local",
      "command": [
        "/home/kali/.nvm/versions/node/v20.20.2/bin/npx",
        "@notionhq/notion-mcp-server"
      ],
      "env": {
        "NOTION_API_KEY": "{env:NOTION_API_KEY}"
      },
      "enabled": false
    }
  },
  "provider": {
    "mtplx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MTPLX (local)",
      "options": {
        "baseURL": "http://100.94.207.1:1234/v1",
        "apiKey": "mtplx.129"
      },
      "models": {
        "Qwen3.6-35B-A3B-MTPLX-Optimized-Speed-FP16": {
          "name": "Qwen3.6-35B-A3B-MTPLX-Optimized-Speed-FP16",
          "image": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    },
    "mac-bonsai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ternary Bonsai (MacBook Pro)",
      "options": {
        "baseURL": "http://100.94.207.1:8080/v1",
        "apiKey": "none"
      },
      "models": {
        "prism-ml/Ternary-Bonsai-27B-Q2_0": {
          "name": "Ternary-Bonsai-27B-Q2_0",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    },
    "llama-server": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Macbook llama-server",
      "options": {
        "baseURL": "http://100.94.207.1:8080/v1",
        "apiKey": "llamacpp"
      },
      "models": {
        "Qwen3.6-35B-A3B-UD-IQ4_NL.gguf.gguf": {
          "name": "Qwen3.6-35B-A3B-UD-IQ4_NL.gguf",
          "image": true,
          "limit": {
            "context": 57344,
            "output": 8192
          },
          "cost": {
            "input": 0.5,
            "output": 3.0
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          }
        },
        "default": {
          "maxTokens": 30000
        }
      }
    }
  },
  "model": "Qwen3.6-35B-A3B-UD-IQ4_NL.gguf.gguf",
  "plugin": [
    "@tarquinen/opencode-dcp"
  ]
}
