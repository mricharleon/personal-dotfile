{
  "$schema": "https://opencode.ai/config.json",
  "compaction": {
    "auto": true,
    "prune": true,
    "keep": {
      "tokens": 2000
    },
    "buffer": 10000
  },
  "permission": {
    "external_directory": {
      "~/.config/opencode/**": "allow",
      "/home/kali/macbookpro/**": "allow",
      "/home/kali/**": "allow"
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": false
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "@modelcontextprotocol/server-filesystem@latest",
        "/home/kali/development"
      ],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "@upstash/context7-mcp@latest"
      ],
      "enabled": true
    },
    "notion": {
      "type": "local",
      "command": [
        "/home/kali/.nvm/versions/node/v20.20.2/bin/npx",
        "@notionhq/notion-mcp-server"
      ],
      "env": {
        "NOTION_API_KEY": "{env:NOTION_API_KEY}"
      },
      "enabled": false
    }
  },
  "provider": {
    "mlx-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MacBook Pro MLX",
      "options": {
        "baseURL": "http://192.168.2.138:8080/v1"
      },
      "models": {
        "/Users/Shared/Qwen3.6-35B-A3B-UD-IQ4_NL/Qwen3.6-35B-A3B-4bit": {
          "name": "Qwen3.6 35B MoE Local",
          "limit": {
            "context": 65536,
            "output": 8192
          }
        }
      }
    },
    "llama-server": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Macbook llama-server",
      "options": {
        "baseURL": "http://192.168.2.138:8080/v1",
        "apiKey": "llamacpp"
      },
      "models": {
        "Qwen3.6-35B-A3B-UD-IQ4_NL.gguf": {
          "name": "Qwen3.6-35B-A3B-UD-IQ4_NL.gguf",
          "image": true,
          "limit": {
            "context": 65536,
            "output": 16384
          },
          "cost": {
            "input": 0.5,
            "output": 3.0
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          }
        },
        "Qwen3.6-27B-IQ4_NL.gguf": {
          "name": "Qwen3.6-27B-IQ4_NL.gguf",
          "image": true,
          "limit": {
            "context": 65536,
            "output": 16384
          },
          "cost": {
            "input": 0.5,
            "output": 3.0
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          }
        },
        "default": {
          "maxTokens": 32768
        }
      }
    }
  },
  "model": "Qwen3.6-35B-A3B-UD-IQ4_NL.gguf",
  "plugin": ["oc-tps@latest"]
}
